# BiliTools-Pro Environment Variables

# App settings
BILITOOLS_DEBUG=false
BILITOOLS_LOG_LEVEL=INFO

# Paths
BILITOOLS_DATA_DIR=./data
BILITOOLS_COOKIES_DIR=./data/cookies
BILITOOLS_CACHE_DIR=./data/cache

# Bilibili API
BILITOOLS_BILIBILI_API_BASE=https://api.bilibili.com
BILITOOLS_BILIBILI_WEB_BASE=https://www.bilibili.com

# Network
BILITOOLS_TIMEOUT=30
BILITOOLS_MAX_RETRIES=3

# IPC Server
BILITOOLS_IPC_HOST=127.0.0.1
BILITOOLS_IPC_PORT=3847